# Ignore generated artifacts by default.
*

# Keep the artifact directory structure versioned.
!.gitkeep
!.gitignore
!models/
!models/.gitkeep

# Evaluation report directories stay versioned, but generated JSON/JSONL outputs
# are ignored by default. Add a specific final report with `git add -f` only if
# the team explicitly decides to version it as delivery evidence.
!evaluation/
!evaluation/.gitkeep
!evaluation/llm_agent/
!evaluation/llm_agent/results/
!evaluation/llm_agent/results/.gitkeep
!evaluation/llm_agent/runs/
!evaluation/llm_agent/runs/.gitkeep
!evaluation/model/
!evaluation/model/.gitkeep
!evaluation/model/drift/
!evaluation/model/drift/.gitkeep
!evaluation/model/retraining/
!evaluation/model/retraining/.gitkeep
!evaluation/model/scenario_experiments/
!evaluation/model/scenario_experiments/.gitkeep
!logs/
!logs/inference/
!logs/inference/.gitkeep
!rag/
!rag/.gitkeep

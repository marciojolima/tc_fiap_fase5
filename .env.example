# Template de variaveis de ambiente.
# Este arquivo nao e lido automaticamente pelo Docker Compose.
# Para usar esses valores, copie este arquivo para `.env`.
# O arquivo `.env` e o que o Docker Compose le automaticamente na raiz do projeto.
PROJECT_ROOT=/app
HOST_UID=1000
HOST_GID=1000
REDIS_PORT=6379
FEAST_REDIS_CONNECTION_STRING=redis:6379
SERVING_PORT=8000
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
OLLAMA_PORT=11434
OLLAMA_MODEL=gemma3:270m
# Override opcional da base URL do provider ativo.
# Em Docker com override do Ollama, o compose injeta LLM_BASE_URL=http://ollama:11434.
# Fora do Docker, pode ser util para apontar para outra instancia sem alterar o YAML.
# LLM_BASE_URL=http://127.0.0.1:11434
# --- API keys de providers externos ---
# Preencha apenas se o llm.active_provider em configs/pipeline_global_config.yaml
# estiver apontando para um provider externo.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
